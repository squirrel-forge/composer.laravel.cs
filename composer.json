{
    "name": "squirrel-forge/lara-cs",
    "description": "Squirrel-Forge Laravel Core Support",
    "version": "0.26.0",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Daniel Hartwell aka. siux",
            "email": "me@siux.info",
            "homepage": "https://siux.info",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "ext-mbstring": "*",
        "ext-http": "*",
        "laravel/framework": ">=11.0"
    },
    "autoload": {
        "psr-4": {
            "SquirrelForge\\Laravel\\CoreSupport\\": "src/"
        },
        "files": [
            "src/helpers.php",
            "src/helpers-global.php"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "extra": {
        "laravel": {
            "providers": [
                "SquirrelForge\\Laravel\\CoreSupport\\Providers\\ServiceProvider"
            ]
        }
    }
}
